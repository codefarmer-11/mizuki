---
import ArchivePanel from "@components/features/archive/ArchivePanel.svelte";
import SectionFilterBar from "@components/features/posts/SectionFilterBar.astro";
import Comment from "@components/comment/index.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	buildSectionTagIndex,
	getCategoriesFromPosts,
	getSortedPostsListByIdPrefix,
} from "@utils/content-utils";
export const prerender = true;

/** 与内容仓库 `posts/essay/` 目录对应（请勿使用 essey 等拼写错误的文件夹名） */
const SECTION = "essay";
const BASE_PATH = "/essay/";
const sortedPostsList = await getSortedPostsListByIdPrefix(SECTION);

const posts = sortedPostsList.map((post) => ({
	...post,
	data: {
		...post.data,
		category: post.data.category === null ? undefined : post.data.category,
	},
}));

const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
const categories = [
	...new Set(
		posts
			.map((post) => post.data.category)
			.filter((c): c is string => typeof c === "string"),
	),
];

const sectionCategories = getCategoriesFromPosts(posts);
const tagIndex = buildSectionTagIndex(posts);

const title = i18n(I18nKey.essay);
---

<MainGridLayout title={title} description={title}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<SectionFilterBar
				basePath={BASE_PATH}
				categories={sectionCategories}
				tagIndex={tagIndex}
				totalCount={posts.length}
			/>
			<ArchivePanel
				sortedPosts={posts}
				tags={tags}
				categories={categories}
				filterBasePath={BASE_PATH}
				client:load
			/>
		</div>
	</div>
	<div class="mt-4">
		<Comment path="/essay/" />
	</div>
</MainGridLayout>
