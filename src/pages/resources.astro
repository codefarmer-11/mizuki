---
import LinkCard from "@components/features/links/LinkCard.astro";
import { PageHeader } from "@components/features/page-header";
import Markdown from "@components/misc/Markdown.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getEntry, render } from "astro:content";

import { siteConfig } from "../config";
import { getShuffledLinksList } from "../data/links";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";

export const prerender = true;

// 3. 功能开关检查：featurePages.friends → featurePages.resources
if (!siteConfig.featurePages.resources) {
	return Astro.redirect("/404/");
}

// 4. 内容条目：spec/friends → spec/links
const linksPost = await getEntry("spec", "links");

if (!linksPost) {
	throw new Error("links page content not found");
}

const { Content } = await render(linksPost);
// 5. 数据获取函数：friends → links
const linksList = getShuffledLinksList();
const allTags = Array.from(new Set(linksList.flatMap((item) => item.tags)));
---

<MainGridLayout
title={i18n(I18nKey.links)}
description={i18n(I18nKey.links)}
>
<script is:inline>
	// 7. 全局标志：isFriendsPage → isLinksPage
	window.isLinksPage = true;
</script>
<script>
	import("../scripts/right-sidebar-layout.js");
</script>

<div
	class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
>
	<div class="card-base z-10 px-9 py-6 relative w-full">
		<PageHeader
		title={i18n(I18nKey.links)}
		subtitle={i18n(I18nKey.linksSubtitle)}
		/>

		<!-- 搜索和筛选栏 -->
		<div class="mb-6 space-y-3">
			<!-- 搜索框 -->
			<div class="w-full">
				<div class="relative">
					<input
						type="text"
					id="links-search"
					placeholder={i18n(I18nKey.linksSearchPlaceholder)}
					class="w-full px-4 py-2 pl-10 rounded-lg bg-[var(--btn-regular-bg)]
					text-black/90 dark:text-white/90
					border border-black/10 dark:border-white/10
					focus:outline-none focus:ring-2 focus:ring-[var(--primary)]/50
					transition-all duration-200"
					/>
					<svg
						class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-black/40 dark:text-white/40"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
						></path>
					</svg>
				</div>
			</div>

			<!-- 标签筛选 -->
			<div class="filter-container flex flex-wrap gap-2">
				<button class="filter-tag active" data-tag="all">
					{i18n(I18nKey.linksFilterAll)}
				</button>
				{
					allTags.map((tag) => (
						<button class="filter-tag" data-tag={tag}>
							{tag}
						</button>
					))
				}
			</div>
		</div>

		<!-- 友链卡片网格 -->
		<div
		id="links-grid"
		class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 mb-6"
		>
		{/* 11. 组件使用：FriendCard → LinkCard，prop 名 friend → link */}
		{linksList.map((item) => <LinkCard link={item} />)}
	</div>

	<!-- 无结果提示 -->
	<div id="no-results" class="hidden text-center py-12">
		<svg
			class="w-16 h-16 mx-auto mb-4 text-black/20 dark:text-white/20"
			fill="none"
			stroke="currentColor"
			viewBox="0 0 24 24"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
				d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
			></path>
		</svg>
		<p class="text-black/50 dark:text-white/50 text-lg">
			{i18n(I18nKey.linksNoResults)}
		</p>
	</div>

	<!-- 说明文档 -->
	<Markdown class="mt-8 prose dark:prose-invert max-w-none">
		<Content />
	</Markdown>

	<!-- 隐藏元素用于传递 i18n 文本到全局脚本 -->
	<div id="links-copy-success-text" style="display: none;">
		{i18n(I18nKey.linksCopySuccess)}
	</div>
</div>
</div>

<!-- 引用全局脚本 -->
<!-- 12. 脚本路径：friends-page-handler.js → links-page-handler.js -->
<script is:inline src="/js/links-page-handler.js"></script>
</MainGridLayout>

<style>
	/* 搜索框焦点效果 */
	#links-search:focus {
		box-shadow: 0 0 0 3px var(--primary) / 0.1;
	}

	/* 标签筛选按钮样式 */
	.filter-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.filter-tag {
		padding: 0.5rem 1rem;
		border: 1px solid var(--line-divider);
		border-radius: var(--radius-large);
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		transition: all 0.2s ease;
		white-space: nowrap;
	}

	.filter-tag:hover:not(.active) {
		background: var(--btn-hover-bg);
		border-color: var(--primary);
		transform: translateY(-1px);
	}

	.filter-tag.active {
		background: var(--primary);
		color: white;
		border-color: var(--primary);
	}

	.filter-tag.active:hover {
		background: var(--primary) !important;
		color: white !important;
		border-color: var(--primary) !important;
		transform: translateY(-1px);
	}
</style>