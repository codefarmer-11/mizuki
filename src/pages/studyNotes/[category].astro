---
import ArchivePanel from "@components/features/archive/ArchivePanel.svelte";
import CategoryBar from "@components/features/posts/CategoryBar.astro";
import Comment from "@components/comment/index.astro";
import { PageHeader } from "@components/features/page-header";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsListByIdPrefix } from "@utils/content-utils";
import {
	getStudyNotesCategoryPathParams,
	getStudyNotesCategorySlugs,
	resolveStudyNotesCategorySlug,
} from "@utils/study-notes-utils";
import { url } from "@utils/url-utils";
import { siteConfig } from "../../config";

export const prerender = true;

export async function getStaticPaths() {
	const categories = getStudyNotesCategoryPathParams();
	return categories.map((category) => ({ params: { category } }));
}

const categorySlugs = getStudyNotesCategorySlugs();
const { category: categoryParam } = Astro.params;
const category = resolveStudyNotesCategorySlug(categoryParam, categorySlugs);

if (!category) {
	return Astro.redirect("/404/");
}

if (categoryParam !== category) {
	return Astro.redirect(
		url(`/studyNotes/${encodeURIComponent(category)}/`),
		301,
	);
}

const SECTION = `studyNotes/${category}`;
const sortedPostsList = await getSortedPostsListByIdPrefix(SECTION);
const showCategoryBar = siteConfig.postListLayout.categoryBar?.enable ?? false;

const posts = sortedPostsList.map((post) => ({
	...post,
	data: {
		...post.data,
		category: post.data.category === null ? undefined : post.data.category,
	},
}));

const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
const categories = [
	...new Set(
		posts
			.map((post) => post.data.category)
			.filter((c): c is string => typeof c === "string"),
	),
];

const baseTitle = i18n(I18nKey.studyNotes);
const title = `${baseTitle} · ${category}`;
---

<MainGridLayout title={title} description={title}>
	{showCategoryBar && <CategoryBar />}
	<script>
		import("../../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<a
				href={url("/studyNotes/")}
				class="mb-4 inline-block text-sm text-50 transition hover:text-[var(--primary)]"
			>
				← {baseTitle}
			</a>
			<PageHeader
				title={category}
				subtitle={baseTitle}
			/>
			<ArchivePanel
				sortedPosts={posts}
				tags={tags}
				categories={categories}
				applyUrlQueryFilters={false}
				client:only="svelte"
			/>
		</div>
	</div>
	<div class="mt-4">
		<Comment path={`/studyNotes/${category}/`} />
	</div>
</MainGridLayout>
