---
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import QRCodeTool from "@components/custom/QRCodeTool.astro";
---

<MainGridLayout
	title={i18n(I18nKey.notFound)}
	description={i18n(I18nKey.notFoundDescription)}
>
	<!-- 引入右侧边栏布局管理器 -->
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>
	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-96"
	>
		<div
			class="card-base z-10 px-9 py-12 relative w-full flex flex-col items-center justify-center text-center"
		>
			<QRCodeTool></QRCodeTool>
		</div>
	</div>
</MainGridLayout>

<style>

</style>
