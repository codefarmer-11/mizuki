---
import ArchivePanel from "@components/features/archive/ArchivePanel.svelte";
import SectionTagBar from "@components/features/posts/SectionTagBar.astro";
import Comment from "@components/comment/index.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getSortedPostsListByIdPrefix,
	getTagsFromPosts,
} from "@utils/content-utils";
import { siteConfig } from "../config";

export const prerender = true;

const SECTION = "cookbook";
const BASE_PATH = "/cookbook/";
const sortedPostsList = await getSortedPostsListByIdPrefix(SECTION);
const showTagBar = siteConfig.postListLayout.categoryBar?.enable ?? false;

const posts = sortedPostsList.map((post) => ({
	...post,
	data: {
		...post.data,
		category: post.data.category === null ? undefined : post.data.category,
	},
}));

const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
const sectionTags = getTagsFromPosts(posts);

const title = i18n(I18nKey.cookbook);
---

<MainGridLayout title={title} description={title}>
	{showTagBar && (
		<SectionTagBar
			basePath={BASE_PATH}
			tags={sectionTags}
			totalCount={posts.length}
		/>
	)}
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<ArchivePanel
		sortedPosts={posts}
		tags={tags}
		categories={[]}
		filterBasePath={BASE_PATH}
		client:load
	/>
	<div class="mt-4">
		<Comment path="/cookbook/" />
	</div>
</MainGridLayout>
