---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import {
	getSectionCategoryUrl,
	getSectionListUrl,
} from "@utils/url-utils";

interface CategoryItem {
	name: string;
	count: number;
}

interface TagItem {
	name: string;
	count: number;
}

interface Props {
	basePath: string;
	categories: CategoryItem[];
	tagIndex: Record<string, TagItem[]>;
	totalCount: number;
	class?: string;
}

const {
	basePath,
	categories,
	tagIndex,
	totalCount,
	class: className,
} = Astro.props;
const sectionListUrl = getSectionListUrl(basePath);
---

<div
	class:list={["card-base section-filter-bar p-3 onload-animation", className]}
	id="section-filter-bar"
	data-base-path={basePath}
	data-tag-index={JSON.stringify(tagIndex)}
>
	<div class="section-filter-inner flex flex-col gap-3">
		<div class="flex gap-2 flex-wrap items-center">
			<a
				href={sectionListUrl}
				class="category-pill text-sm px-3 py-1 rounded-lg whitespace-nowrap flex-shrink-0
					   transition-colors duration-200 flex items-center justify-center"
				data-section-filter="all"
			>
				{i18n(I18nKey.projectsAll)}
				<span class="text-xs opacity-60 ml-1">{totalCount}</span>
			</a>
			{
				categories.length > 0 && (
					<div class="category-divider flex-shrink-0" />
				)
			}
			<div class="flex gap-2 flex-wrap">
				{
					categories.map((cat) => (
						<a
							href={getSectionCategoryUrl(basePath, cat.name)}
							class="category-pill text-sm px-3 py-1 rounded-lg whitespace-nowrap
								   transition-colors duration-200 flex items-center justify-center"
							data-section-category={cat.name}
						>
							{cat.name}
							<span class="text-xs opacity-60 ml-1">
								{cat.count}
							</span>
						</a>
					))
				}
			</div>
		</div>
		<div
			class="section-tag-row flex gap-2 flex-wrap min-h-[2rem]"
			id="section-tag-row"
			aria-label={i18n(I18nKey.tags)}
		>
		</div>
	</div>
</div>

<style>
	.section-filter-bar {
		margin-bottom: 1rem;
	}
	.category-divider {
		width: 1px;
		align-self: stretch;
		background: var(--line-divider);
	}
	.category-pill,
	.section-tag-pill {
		border: 1.5px solid var(--line-divider);
		color: var(--btn-content);
		background: transparent;
	}
	.category-pill:hover,
	.section-tag-pill:hover {
		border-color: var(--primary);
		color: var(--primary);
		background: transparent;
	}
	.category-pill[data-active],
	.section-tag-pill[data-active] {
		background: var(--primary);
		border-color: var(--primary);
		color: white;
	}
	.category-pill[data-active]:hover,
	.section-tag-pill[data-active]:hover {
		background: var(--primary);
		border-color: var(--primary);
		opacity: 0.9;
	}
</style>

<script>
	import { getSectionTagUrl } from "@utils/url-utils";

	type TagItem = { name: string; count: number };

	function updateSectionFilterBar() {
		const bar = document.getElementById("section-filter-bar");
		const tagRow = document.getElementById("section-tag-row");
		if (!bar || !tagRow) {
			return;
		}

		const basePath = bar.getAttribute("data-base-path") || "/";
		let tagIndex: Record<string, TagItem[]> = {};
		try {
			tagIndex = JSON.parse(bar.getAttribute("data-tag-index") || "{}");
		} catch {
			tagIndex = {};
		}

		const params = new URLSearchParams(window.location.search);
		const activeCategory = params.get("category") || "";
		const activeTags = params.getAll("tag");

		bar.querySelectorAll<HTMLElement>("[data-section-filter]").forEach((el) => {
			el.removeAttribute("data-active");
		});
		bar.querySelectorAll<HTMLElement>("[data-section-category]").forEach(
			(el) => {
				el.removeAttribute("data-active");
			},
		);

		if (activeCategory) {
			const catPill = bar.querySelector<HTMLElement>(
				`[data-section-category="${CSS.escape(activeCategory)}"]`,
			);
			catPill?.setAttribute("data-active", "");
		} else if (!params.has("tag") && !params.has("uncategorized")) {
			bar.querySelector<HTMLElement>("[data-section-filter]")?.setAttribute(
				"data-active",
				"",
			);
		}

		const tagsForCategory = tagIndex[activeCategory] ?? tagIndex[""] ?? [];
		tagRow.replaceChildren();

		for (const t of tagsForCategory) {
			const href = getSectionTagUrl(
				basePath,
				t.name,
				activeCategory || undefined,
			);
			const pill = document.createElement("a");
			pill.href = href;
			pill.className =
				"section-tag-pill text-xs px-2 py-1 rounded-lg whitespace-nowrap transition-colors duration-200";
			pill.setAttribute("data-section-tag", t.name);
			pill.setAttribute(
				"aria-label",
				`View posts tagged with ${t.name.trim()}`,
			);
			pill.textContent = `# ${t.name.trim()}`;
			if (activeTags.includes(t.name)) {
				pill.setAttribute("data-active", "");
			}
			tagRow.appendChild(pill);
		}
	}

	updateSectionFilterBar();
	document.addEventListener("astro:page-load", updateSectionFilterBar);
	document.addEventListener("swup:contentReplaced", updateSectionFilterBar);
</script>
