---
// 组件：QRCodeTool.astro
// 已修复 TypeScript 类型错误，通过 astro check 检查

import QRCode from 'qrcode'
import jsQR from 'jsqr'

// --- 生成部分 ---
const canvas = document.getElementById('qrCanvas') as HTMLCanvasElement | null
const input = document.getElementById('qrInput') as HTMLInputElement | null
const genBtn = document.getElementById('generateBtn') as HTMLButtonElement | null

// 初始化时检查必须元素
if (!canvas || !input || !genBtn) {
	throw new Error('生成二维码所需的 DOM 元素未找到')
}

async function generateQR() {
	// TypeScript 仍然会在此函数作用域内认为 input 可能为 null，使用非空断言或局部变量
	const text = input!.value.trim()
	if (!text) {
		alert('请输入内容')
		return
	}
	try {
		await QRCode.toCanvas(canvas!, text, { width: 250, margin: 2 })
	} catch (err) {
		alert('生成失败：' + (err instanceof Error ? err.message : String(err)))
	}
}

genBtn.addEventListener('click', generateQR)
generateQR() // 默认生成示例

// --- 解析部分 ---
const fileInput = document.getElementById('qrFile') as HTMLInputElement | null
const resultDiv = document.getElementById('decodeResult') as HTMLDivElement | null
const previewImg = document.getElementById('previewImg') as HTMLImageElement | null

if (!fileInput || !resultDiv || !previewImg) {
	throw new Error('解析二维码所需的 DOM 元素未找到')
}

fileInput.addEventListener('change', (e: Event) => {
	const target = e.target as HTMLInputElement | null
	const file = target?.files?.[0]
	if (!file) return

	const url = URL.createObjectURL(file)
	previewImg.src = url
	previewImg.style.display = 'block'
	resultDiv.textContent = '🔍 解析中...'

	const img = new Image()
	img.src = url
	img.onload = () => {
		const canvasElem = document.createElement('canvas')
		const ctx = canvasElem.getContext('2d')
		if (!ctx) {
			resultDiv.textContent = '无法获取 Canvas 上下文'
			return
		}

		const maxWidth = 800
		let width = img.width
		let height = img.height
		if (width > maxWidth) {
			height = Math.floor(height * (maxWidth / width))
			width = maxWidth
		}

		canvasElem.width = width
		canvasElem.height = height
		ctx.drawImage(img, 0, 0, width, height)

		const imageData = ctx.getImageData(0, 0, width, height)
		const code = jsQR(imageData.data, width, height)

		if (code) {
			resultDiv.textContent = code.data
		} else {
			resultDiv.textContent = '❌ 未识别到二维码，请确保图片清晰'
		}

		URL.revokeObjectURL(url)
	}

	img.onerror = () => {
		resultDiv.textContent = '图片加载失败，请重试'
		URL.revokeObjectURL(url)
	}
})

---

<div class="qr-tool">
	<!-- 左侧：生成 -->
	<div class="qr-panel">
		<div class="panel-header">
			<span class="icon">📱</span>
			<h3>生成二维码</h3>
		</div>
		<div class="panel-body">
			<input type="text" id="qrInput" placeholder="输入文字或链接" value="https://astro.build" />
			<button id="generateBtn">生成二维码</button>
			<div class="qr-canvas-container">
				<canvas id="qrCanvas"></canvas>
			</div>
			<p class="footnote">支持文字、网址，点击按钮即生成</p>
		</div>
	</div>

	<!-- 右侧：解析 -->
	<div class="qr-panel">
		<div class="panel-header">
			<span class="icon">🔍</span>
			<h3>解析二维码</h3>
		</div>
		<div class="panel-body">
			<label for="qrFile" class="file-label">
				<span>📁 选择图片上传</span>
			</label>
			<input type="file" id="qrFile" accept="image/*" hidden />
			<div class="preview-box">
				<img id="previewImg" alt="预览图" style="display: none;" />
			</div>
			<div class="result-box" id="decodeResult">等待上传图片...</div>
			<p class="footnote">支持拍照、截图，本地解析，安全快速</p>
		</div>
	</div>
</div>

<style>
    .qr-tool {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        justify-content: center;
        margin: 2rem 0;
    }

    .qr-panel {
        flex: 1 1 300px;
        max-width: 360px;
        background: transparent;
        border-radius: 0;
        padding: 0;
        box-shadow: none;
    }

    .panel-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-border, #eaeaea);
        padding-bottom: 0.75rem;
    }

    .panel-header .icon {
        font-size: 1.5rem;
    }

    .panel-header h3 {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 500;
        color: var(--color-text, #222);
    }

    .panel-body {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    input[type="text"] {
        width: 100%;
        padding: 12px 16px;
        font-size: 1rem;
        border: 1px solid var(--color-border, #ddd);
        border-radius: 8px;
        background: var(--color-bg-secondary, #f9f9f9);
        transition: border-color 0.2s;
        box-sizing: border-box;
    }

    input[type="text"]:focus {
        outline: none;
        border-color: var(--color-primary, #0070f3);
        background: var(--color-bg, #fff);
    }

    button {
        background: var(--color-primary, #0070f3);
        color: white;
        border: none;
        padding: 12px 16px;
        font-size: 1rem;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        transition: background 0.2s;
        width: 100%;
    }

    button:hover {
        background: #0051a2;
    }

    .file-label {
        display: inline-block;
        width: 100%;
        padding: 12px 16px;
        background: var(--color-bg-secondary, #f5f5f5);
        border: 1px dashed var(--color-border, #ccc);
        border-radius: 8px;
        text-align: center;
        cursor: pointer;
        transition: border 0.2s;
        box-sizing: border-box;
    }

    .file-label:hover {
        border-color: var(--color-primary, #0070f3);
        background: var(--color-bg, #fff);
    }

    .qr-canvas-container {
        display: flex;
        justify-content: center;
        margin: 0.5rem 0;
    }

    canvas {
        display: block;
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        border: none;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .preview-box {
        display: flex;
        justify-content: center;
        min-height: 100px;
    }

    #previewImg {
        max-width: 100%;
        max-height: 200px;
        object-fit: contain;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .result-box {
        padding: 14px 16px;
        background: var(--color-bg-secondary, #f9f9f9);
        border-radius: 8px;
        font-family: 'JetBrains Mono', monospace;
        word-break: break-all;
        font-size: 0.95rem;
        border: 1px solid var(--color-border, #eee);
    }

    .footnote {
        font-size: 0.8rem;
        color: var(--color-text-secondary, #777);
        margin: 0.5rem 0 0 0;
        text-align: center;
    }

    :root {
        --color-primary: #0070f3;
        --color-bg: #ffffff;
        --color-bg-secondary: #f9f9f9;
        --color-text: #222222;
        --color-text-secondary: #666666;
        --color-border: #e0e0e0;
    }

    html.dark {
        --color-bg: #1e1e1e;
        --color-bg-secondary: #2d2d2d;
        --color-text: #eeeeee;
        --color-text-secondary: #aaaaaa;
        --color-border: #444444;
    }

    @media (max-width: 640px) {
        .qr-tool {
            gap: 1rem;
        }
    }
</style>

